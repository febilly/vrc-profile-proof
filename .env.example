# VRChat requires a descriptive User-Agent with an application name, version,
# and a way to contact the operator.
VRC_USER_AGENT=vrc-profile-proof-example/0.1 contact@example.com

# This is the service operator's VRChat session, never an end user's cookie.
VRC_AUTH_COOKIE=authcookie_xxxxx
# VRC_TWO_FACTOR_AUTH_COOKIE=xxxxxxxx
